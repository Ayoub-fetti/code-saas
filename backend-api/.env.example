APP_NAME="Fret Marketplace"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fret_marketplace
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

FRONTEND_URLS=http://localhost:5173,http://localhost:5174
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174

# Tarif de base par km selon le type de camion (utilisé pour le calcul auto du prix)
TARIF_KM_LEGER=6
TARIF_KM_MOYEN=9
TARIF_KM_LOURD=13
